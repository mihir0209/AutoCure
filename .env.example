# ============================================
# Self-Healing Software System v2.0 Configuration
# ============================================
# Copy this file to .env and fill in your values

# =============================================================================
# AI Provider Configuration
# =============================================================================
# Options: "groq" or "cerebras" (both have free tiers)
AI_PROVIDER=groq

# Groq API Configuration
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras API Configuration
# Get your API key at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b

# AI request settings
AI_MAX_RETRIES=5
AI_INITIAL_RETRY_DELAY=2.0
AI_MAX_TOKENS=8192

# =============================================================================
# PostgreSQL Database Configuration
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=selfhealer
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_MIN_CONNECTIONS=5
DB_MAX_CONNECTIONS=20
DB_SSL=false
# IMPORTANT: Change this in production!
DB_ENCRYPTION_KEY=change-this-encryption-key-in-production-32chars

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WEBSOCKET_PATH=/ws/logs
API_PREFIX=/api/v1
# IMPORTANT: Change this in production!
JWT_SECRET=change-this-jwt-secret-in-production-minimum-32-chars
JWT_EXPIRY_HOURS=24

# =============================================================================
# GitHub Configuration (Read-Only Access)
# =============================================================================
# Personal access token with repo:read scope
# User generates this from their own GitHub account
GITHUB_TOKEN=your_github_token_here

# Base path where user repositories will be cloned
GIT_REPOS_BASE_PATH=./repos

# Interval for periodic git pull (in minutes)
GIT_PULL_INTERVAL_MINUTES=5

# Webhook secret for PR notifications (optional)
GITHUB_WEBHOOK_SECRET=

# =============================================================================
# Email Notification Configuration
# =============================================================================
# Using Gmail with App Password (recommended)
# To create an app password:
# 1. Go to Google Account > Security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords and generate one

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
# Admin sender email (all emails sent from this address)
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here
# Fallback admin email (per-repo admin can be set in database)
ADMIN_EMAIL=admin@example.com
ENABLE_EMAIL_NOTIFICATIONS=true

# =============================================================================
# Storage Tier Configuration
# =============================================================================
# Free tier limits
FREE_MAX_REPOS=5
FREE_MAX_STORAGE_MB=100

# Pro tier limits (for future use)
PRO_MAX_REPOS=999999
PRO_MAX_STORAGE_MB=1024

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
RATE_LIMIT_LOGS_PER_SEC=100
RATE_LIMIT_PRS_PER_HOUR=10
RATE_LIMIT_API_PER_MIN=60

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# Error Analysis Settings
# =============================================================================
# Number of payload variations to try when replicating errors
ERROR_REPLICATION_VARIATIONS=8

# Maximum depth for AST traversal
AST_MAX_DEPTH=20

# Cooldown between error analysis (in seconds) to prevent rate limiting
ANALYSIS_COOLDOWN_SECONDS=30
