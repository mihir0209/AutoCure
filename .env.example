# ============================================
# Self-Healing Software System Configuration
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# AI Provider Configuration
# --------------------------------------------
# Options: 'groq' or 'cerebras'
AI_PROVIDER=groq

# Groq API Configuration
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras API Configuration  
# Get your API key at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b

# --------------------------------------------
# Email Notification Configuration
# --------------------------------------------
# Using Gmail with App Password (recommended)
# To create an app password:
# 1. Go to Google Account > Security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords and generate one

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password_here
ADMIN_EMAIL=admin@example.com
ENABLE_NOTIFICATIONS=true

# --------------------------------------------
# Git Configuration
# --------------------------------------------
GIT_REPO_PATH=./
GIT_BRANCH_PREFIX=ai-fix
GIT_AUTO_COMMIT=true
GIT_REMOTE_NAME=origin

# --------------------------------------------
# System Configuration
# --------------------------------------------
# Path to the log file to monitor
LOG_FILE=./logs/service.log

# Path to the target service to heal
TARGET_SERVICE_PATH=./demo_service

# Maximum number of fix attempts before giving up
MAX_FIX_ATTEMPTS=5

# Interval in seconds between log checks
LOG_WATCH_INTERVAL=1.0

# Timeout in seconds for test execution
TEST_TIMEOUT=60
